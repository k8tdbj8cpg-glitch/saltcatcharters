# Stripe API Keys
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Coinbase Commerce API Key
# Get this from https://commerce.coinbase.com/settings/security
COINBASE_COMMERCE_API_KEY=your_coinbase_commerce_api_key
COINBASE_COMMERCE_WEBHOOK_SECRET=your_coinbase_webhook_shared_secret

# Dream Log Stripe Subscription Price IDs
# Create these in your Stripe dashboard under Products
DREAM_LOG_MONTHLY_PRICE_ID=price_...
DREAM_LOG_ONETIME_PRICE_ID=price_...
